---
import '../styles/tokens.css';
import '../styles/main.css';
import { Image } from 'astro:assets';
import logo from '../assets/logo-lautstarke-freunde.png';

interface Props {
  title: string;
  description?: string;
  accent?: string;
}

const {
  title,
  description = 'Logopädische Kinderbücher, die spielerisch Laute trainieren.',
  accent,
} = Astro.props;
---

<!doctype html>
<html lang="de" style={accent ? `--accent:${accent}` : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · Lautstarke Freunde</title>
  </head>
  <body>
    <header class="site-header">
      <a class="site-header__brand" href="/" aria-label="Lautstarke Freunde, zur Startseite">
        <Image
          src={logo}
          alt="Lautstarke Freunde"
          class="site-header__logo"
          widths={[160, 240, 320]}
          sizes="(max-width: 36rem) 160px, 220px"
          loading="eager"
          decoding="async"
        />
      </a>
      <nav class="site-header__nav" aria-label="Hauptnavigation">
        <a href="/">Start</a>
        <a href="/#books">Bücher</a>
        <a href="/#contact">Kontakt</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} Lautstarke Freunde</p>
      <p><a href="mailto:info@lautstarke-freunde.de">info@lautstarke-freunde.de</a></p>
      <nav aria-label="Soziale Medien">
        <a
          class="site-footer__social"
          href="https://www.instagram.com/lautstarkefreunde/"
          target="_blank"
          rel="me noopener noreferrer"
          aria-label="Lautstarke Freunde auf Instagram"
        >
          <svg
            class="site-footer__icon"
            viewBox="0 0 24 24"
            width="20"
            height="20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            focusable="false"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
          <span>Instagram</span>
        </a>
      </nav>
      <nav aria-label="Rechtliches">
        <a href="/imprint">Impressum</a>
        <a href="/privacy">Datenschutz</a>
      </nav>
    </footer>
  </body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

import { friends } from '../data/friends';

// Hero figure cut-outs — one per friend, imported individually so the
// designer can position them freely via modifier classes.
import fanniFigure from '../assets/figures/fanni-fuchs.png';
import karloFigure from '../assets/figures/karlo-kater.png';
import rudiFigure  from '../assets/figures/rudi-raupe.png';

import instagramQr from '../assets/instagram-qr-card.png';
---

<BaseLayout title="Startseite">

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero__content">
      <h1 id="hero-heading" class="hero__title">Lautstarke Freunde</h1>
      <p class="hero__lead">
        Logopädische Kinderbücher, die spielerisch einzelne Laute trainieren.
        Jeder Laut hat seinen eigenen tierischen Freund:
        <strong>Fanni Fuchs</strong> übt den Laut /f/,
        <strong>Karlo Kater</strong> den Laut /k/ und
        <strong>Rudi Raupe</strong> den Laut /r/.
      </p>
      <a href="#books" class="hero__cta">Bücher entdecken</a>
      <p class="hero__secondary">
        <a href="#friends">Alle Freunde ansehen</a>
      </p>
    </div>

    <!--
      Three figure cut-outs shown as a decorative trio.
      Each has a BEM modifier so the designer can control size and position
      per character independently.
      aria-hidden on the group because the names appear in the body text.
    -->
    <div class="hero__figures" aria-hidden="true">
      <Image
        src={fanniFigure}
        alt=""
        class="hero__figure-image hero__figure-image--fanni"
        widths={[200, 360, 520]}
        sizes="(max-width: 600px) 30vw, 260px"
        loading="eager"
        decoding="async"
      />
      <Image
        src={karloFigure}
        alt=""
        class="hero__figure-image hero__figure-image--karlo"
        widths={[200, 360, 520]}
        sizes="(max-width: 600px) 30vw, 260px"
        loading="eager"
        decoding="async"
      />
      <Image
        src={rudiFigure}
        alt=""
        class="hero__figure-image hero__figure-image--rudi"
        widths={[200, 360, 520]}
        sizes="(max-width: 600px) 30vw, 260px"
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  <!-- ============================================================
       ABOUT THE PROJECT
       ============================================================ -->
  <section class="about" aria-labelledby="about-heading">
    <h2 id="about-heading" class="about__title">Was sind Lautstarke Freunde?</h2>
    <p class="about__text">
      Kinder, die einen bestimmten Laut noch üben, brauchen spielerische
      Unterstützung, zu Hause und in der Therapie. Unsere Bücher begleiten
      sie dabei: eine Figur, ein Laut, viele Abenteuer. Der Ziellaut taucht
      in der Geschichte immer wieder auf, ganz natürlich eingebettet.
      Fachleute nennen das <strong>Inputspezifizierung</strong>: Je öfter ein
      Kind einen Laut in Wörtern und Sätzen hört, desto besser kann es ihn
      wahrnehmen und später selbst verwenden.
    </p>
    <ul class="about__features" role="list">
      <li class="feature">
        <span class="feature__icon" aria-hidden="true">🐾</span>
        <span class="feature__text">Tierische Hauptfiguren für Ziellaute</span>
      </li>
      <li class="feature">
        <span class="feature__icon" aria-hidden="true">🗣️</span>
        <span class="feature__text">Von Logopäden entwickelt</span>
      </li>
      <li class="feature">
        <span class="feature__icon" aria-hidden="true">🎨</span>
        <span class="feature__text">Mit interaktiven Seiten</span>
      </li>
      <li class="feature">
        <span class="feature__icon" aria-hidden="true">👨‍👩‍👧</span>
        <span class="feature__text">Für Eltern und Therapeuten</span>
      </li>
    </ul>
  </section>

  <!-- ============================================================
       BOOKS OVERVIEW
       Driven by the friends data array so all three books appear,
       including upcoming ones with a "Bald" badge.
       ============================================================ -->
  <section id="books" class="books-overview" aria-labelledby="books-heading">
    <h2 id="books-heading" class="books-overview__title">Unsere Bücher</h2>

    <ul class="books-list" role="list">
      {friends.map((friend) => (
        <li class="books-list__item">
          {/*
            Per-character modifier (book-card--fanni/--rudi/--karlo) drives
            accent colours. Status modifiers (--review/--upcoming) are removed:
            state is now expressed solely via the button enabled/disabled pattern.
          */}
          <article
            class:list={['book-card', `book-card--${friend.key}`]}
            aria-label={friend.bookTitle}
          >
            {/* Cover — linked when an on-site page exists, plain wrap otherwise.
                No status badges: the buttons below communicate availability. */}
            {friend.href ? (
              <a href={friend.href} class="book-card__cover-link" tabindex="-1" aria-hidden="true">
                <Image
                  src={friend.cover}
                  alt=""
                  class="book-card__cover"
                  widths={[220, 360, 480]}
                  sizes="(max-width: 600px) 70vw, 280px"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            ) : (
              <div class="book-card__cover-wrap" aria-hidden="true">
                <Image
                  src={friend.cover}
                  alt=""
                  class="book-card__cover"
                  widths={[220, 360, 480]}
                  sizes="(max-width: 600px) 70vw, 280px"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}

            <header class="book-card__head">
              <p class="book-card__sound" aria-label={`Ziellaut: ${friend.sound}`}>
                Laut <strong>{friend.sound}</strong>
              </p>
              <h3 class="book-card__title">{friend.bookTitle}</h3>
            </header>

            <p class="book-card__age">{friend.age}</p>

            {/*
              Unified two-button actions area — always both buttons present.
              Button 1 (primary): "Bei Amazon kaufen"
                Active   → <a> when amazonUrl is set AND status is 'available'.
                Disabled → <button disabled> otherwise (e.g. Fanni in review).
              Button 2 (secondary): "Mehr erfahren"
                Active   → <a> when an on-site detail page (href) exists.
                Disabled → <button disabled> when no page exists yet (e.g. Karlo).
            */}
            <div class="book-card__actions">
              {friend.amazonUrl && friend.status === 'available' ? (
                <a
                  href={friend.amazonUrl}
                  class="book-card__buy-button"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${friend.bookTitle} bei Amazon kaufen`}
                >
                  Bei Amazon kaufen
                </a>
              ) : (
                <button
                  type="button"
                  class="book-card__buy-button book-card__buy-button--disabled"
                  disabled
                  aria-label="Bald bei Amazon erhältlich"
                >
                  Bei Amazon kaufen
                </button>
              )}

              {friend.href ? (
                <a
                  href={friend.href}
                  class="book-card__more-link"
                  aria-label={`Mehr zu ${friend.bookTitle}`}
                >
                  Mehr erfahren
                </a>
              ) : (
                <button
                  type="button"
                  class="book-card__more-link book-card__more-link--construction"
                  disabled
                  aria-label="Seite im Aufbau"
                >
                  Im Aufbau
                </button>
              )}
            </div>
          </article>
        </li>
      ))}
    </ul>
  </section>

  <!-- ============================================================
       FRIENDS ENSEMBLE
       ============================================================ -->
  <section id="friends" class="friends" aria-labelledby="friends-heading">
    <h2 id="friends-heading" class="friends__title">Lern die Freunde kennen</h2>
    <p class="friends__lead">
      Drei Freunde, drei Laute, drei Abenteuer. Jeder Freund trainiert
      spielerisch genau einen Ziellaut und begleitet Kinder durch eine
      Geschichte voller Überraschungen.
    </p>
    <ul class="friends__grid" role="list">
      {friends.map((friend) => (
        // Per-character modifier (friend-card--fanni/--rudi/--karlo) drives accent colours.
        // Status modifiers (--soon/--review) removed; state lives in the buttons below.
        <li class:list={['friend-card', `friend-card--${friend.key}`]}>
          <div class="friend-card__image-area">
            <Image
              src={friend.image}
              alt={friend.alt}
              class="friend-card__image"
              widths={[160, 240, 320]}
              sizes="(max-width: 600px) 40vw, 220px"
              loading="lazy"
              decoding="async"
            />
          </div>
          <p class="friend-card__sound">Laut <strong>{friend.sound}</strong></p>
          <h3 class="friend-card__name">{friend.name}</h3>
          <p class="friend-card__text">{friend.description}</p>

          {/*
            Unified two-button actions area — always both buttons present.
            Button 1 (primary): "Bei Amazon kaufen"
              Active   → <a> when amazonUrl is set AND status is 'available'.
              Disabled → <button disabled> otherwise.
            Button 2 (secondary): "Mehr erfahren"
              Active   → <a> when an on-site detail page (href) exists.
              Disabled → <button disabled> when no page exists yet.
          */}
          <div class="friend-card__actions">
            {friend.amazonUrl && friend.status === 'available' ? (
              <a
                href={friend.amazonUrl}
                class="friend-card__buy-button"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${friend.name}: Bei Amazon kaufen`}
              >
                Bei Amazon kaufen
              </a>
            ) : (
              <button
                type="button"
                class="friend-card__buy-button friend-card__buy-button--disabled"
                disabled
                aria-label="Bald bei Amazon erhältlich"
              >
                Bei Amazon kaufen
              </button>
            )}

            {friend.href ? (
              <a
                class="friend-card__more-link"
                href={friend.href}
                aria-label={`Mehr zu ${friend.name}`}
              >
                Mehr erfahren
              </a>
            ) : (
              <button
                type="button"
                class="friend-card__more-link friend-card__more-link--construction"
                disabled
                aria-label="Seite im Aufbau"
              >
                Im Aufbau
              </button>
            )}
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- ============================================================
       AUDIENCES
       ============================================================ -->
  <section class="audiences" aria-labelledby="audiences-heading">
    <h2 id="audiences-heading" class="audiences__title">Für wen sind die Bücher?</h2>
    <div class="audiences__grid">
      <div class="audience">
        <h3 class="audience__name">Eltern</h3>
        <p class="audience__text">
          Gemeinsam lesen und dabei spielerisch üben, ganz ohne Therapieatmosphäre.
        </p>
      </div>
      <div class="audience">
        <h3 class="audience__name">Logopäd:innen</h3>
        <p class="audience__text">
          Ergänzendes Material für die Übungseinheit oder als Hausaufgabe.
        </p>
      </div>
      <div class="audience">
        <h3 class="audience__name">Erzieher:innen</h3>
        <p class="audience__text">
          Im Alltag der Kita als Vorleserunde mit Sprachfördereffekt nutzbar.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INSTAGRAM
       Branded QR (Instagram nametag, cropped to its white card) framed
       in a site-styled band. Plain outbound link — no embed/pixel.
       ============================================================ -->
  <section id="instagram" class="instagram" aria-labelledby="instagram-heading">
    <h2 id="instagram-heading" class="instagram__title">Folge uns auf Instagram</h2>
    <p class="instagram__intro">
      Neuigkeiten, Einblicke hinter die Kulissen und neue Freunde.
      Scanne den Code mit deinem Handy oder besuche uns direkt.
    </p>

    <div class="instagram__card">
      <Image
        src={instagramQr}
        alt="QR Code zum Instagram Profil von Lautstarke Freunde"
        class="instagram__qr"
        widths={[220, 320, 440]}
        sizes="(max-width: 600px) 60vw, 300px"
        loading="lazy"
        decoding="async"
      />
      <p class="instagram__handle">@lautstarkefreunde</p>
      <a
        class="hero__cta instagram__cta"
        href="https://www.instagram.com/lautstarkefreunde/"
        target="_blank"
        rel="me noopener noreferrer"
      >
        Zum Profil
      </a>
    </div>
  </section>

  <!-- ============================================================
       CONTACT
       Static-friendly contact point: a plain mailto, no form / no
       third-party service, so no extra GDPR processing is introduced.
       The same address is the §5 DDG contact for the Impressum.
       ============================================================ -->
  <section id="contact" class="contact" aria-labelledby="contact-heading">
    <h2 id="contact-heading" class="contact__title">Kontakt</h2>
    <p class="contact__intro">
      Fragen, Feedback oder Interesse an unseren Büchern? Schreib uns gern.
      Wir freuen uns über jede Nachricht.
    </p>

    <div class="contact__card">
      <p class="contact__label">Schreib uns eine E-Mail:</p>
      <a class="hero__cta contact__email" href="mailto:info@lautstarke-freunde.de">
        info@lautstarke-freunde.de
      </a>
    </div>
  </section>

</BaseLayout>
